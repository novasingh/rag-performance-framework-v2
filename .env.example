# =============================================================================
# RAG Performance Framework - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# =============================================================================

# ── DigitalOcean Inference API ────────────────────────────────────────────────
# Required for LLM generation (RAG response generation)
# Get your key at: https://cloud.digitalocean.com/account/api/tokens
DO_API_KEY=your_do_api_key_here

# Optional: override the default model
# DO_MODEL_NAME=llama-4-maverick

# ── Google AI Studio (Gemma models) ───────────────────────────────────────────
# Optional: used if GENERATOR_BACKEND=google
# Get your key at: https://aistudio.google.com/app/apikey
# GOOGLE_AI_API_KEY=your_google_api_key_here

# ── Ollama (Local) ───────────────────────────────────────────────────────────
# Optional: used if GENERATOR_BACKEND=ollama (free, runs locally)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ── Active Generator Backend ──────────────────────────────────────────────────
# Options: digitalocean (default), ollama, google
# GENERATOR_BACKEND=digitalocean
